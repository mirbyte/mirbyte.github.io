<div id="custom-cursor" class="custom-cursor" aria-hidden="true">
	<span class="custom-cursor__ring"></span>
	<span class="custom-cursor__core"></span>
	<span class="custom-cursor__icon-shadow" aria-hidden="true"></span>
	<span class="custom-cursor__label" aria-hidden="true">Download latest</span>
	<svg
		class="custom-cursor__download"
		viewBox="0 0 24 24"
		fill="none"
		stroke="currentColor"
		stroke-width="2"
		stroke-linecap="round"
		stroke-linejoin="round"
		aria-hidden="true"
	>
		<g class="custom-cursor__download-arrow">
			<path class="custom-cursor__download-stem" d="M12 4v10"></path>
			<path class="custom-cursor__download-head" d="m8 10 4 4 4-4"></path>
		</g>
		<path class="custom-cursor__download-tray" d="M6 20h12"></path>
	</svg>
	<svg
		class="custom-cursor__external"
		viewBox="0 0 24 24"
		fill="none"
		stroke="currentColor"
		stroke-width="2"
		stroke-linecap="round"
		stroke-linejoin="round"
		aria-hidden="true"
	>
		<path class="custom-cursor__external-line" d="M7 17 17 7"></path>
		<path class="custom-cursor__external-corner" d="M7 7h10v10"></path>
	</svg>
</div>

<script>
	const cursor = document.getElementById("custom-cursor");
	const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
	const finePointer = window.matchMedia("(pointer: fine)");
	const canHover = window.matchMedia("(hover: hover)");

	if (!cursor || reducedMotion.matches || !finePointer.matches || !canHover.matches) {
		cursor?.remove();
	} else {
		let targetX = 0;
		let targetY = 0;
		let currentX = 0;
		let currentY = 0;
		let active = false;

		const paint = () => {
			currentX += (targetX - currentX) * 0.28;
			currentY += (targetY - currentY) * 0.28;
			cursor.style.left = `${currentX}px`;
			cursor.style.top = `${currentY}px`;
			requestAnimationFrame(paint);
		};

		const show = (x: number, y: number) => {
			targetX = x;
			targetY = y;

			if (!active) {
				active = true;
				currentX = x;
				currentY = y;
				document.body.classList.add("has-custom-cursor");
				requestAnimationFrame(paint);
			}

			cursor.classList.add("is-visible");
		};

		document.addEventListener(
			"mousemove",
			(event) => {
				show(event.clientX, event.clientY);
			},
			{ passive: true },
		);

		document.addEventListener("mouseover", (event) => {
			const el = event.target as Element;
			const download = el.closest(".repo-download");
			const repoLink = el.closest(".repo-link");
			const interactive = el.closest(
				'a[href], button:not(:disabled), [role="button"]:not([aria-disabled="true"])',
			);

			cursor.classList.toggle("is-download", Boolean(download));
			cursor.classList.toggle("is-repo-link", Boolean(repoLink) && !download);

			const label = cursor.querySelector(".custom-cursor__label");
			if (label instanceof HTMLElement) {
				if (download) {
					label.textContent =
						download.getAttribute("data-cursor-label") ?? "Download latest";
				} else if (repoLink) {
					label.textContent = repoLink.getAttribute("data-cursor-label") ?? "Open on GitHub";
				}
			}

			if (repoLink) {
				const accent = getComputedStyle(repoLink).getPropertyValue("--cursor-accent").trim();
				if (accent) cursor.style.setProperty("--cursor-accent", accent);
			} else {
				cursor.style.removeProperty("--cursor-accent");
			}

			cursor.classList.toggle("is-hover", Boolean(interactive) && !download && !repoLink);
		});

		document.documentElement.addEventListener("mouseleave", () => {
			cursor.classList.remove("is-visible");
		});

		document.documentElement.addEventListener("mouseenter", () => {
			if (active) cursor.classList.add("is-visible");
		});
	}
</script>
