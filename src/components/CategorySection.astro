---
import { categoryAccents, type RepoCategory } from "../data/repos";
import RepoCard from "./RepoCard.astro";

interface Props {
	category: RepoCategory;
	index: number;
}

const { category, index } = Astro.props;
const accent = categoryAccents[category.id] ?? "#4db8ff";
const categoryNumber = String(index + 1).padStart(2, "0");
---

<section
	id={category.id}
	class="category-section scroll-mt-28"
	style={`--category-accent: ${accent}`}
>
	<div class="category-section-header relative mb-6 pl-8">
		<span class="modern-only category-watermark pointer-events-none absolute -left-2 top-1/2 -translate-y-1/2 select-none font-mono text-[clamp(4rem,14vw,7rem)] font-bold leading-none tabular-nums" aria-hidden="true">
			{categoryNumber}
		</span>

		<span class="modern-only category-node pointer-events-none absolute left-0 top-1/2 z-10 h-2 w-2 -translate-x-1/2 -translate-y-1/2 rounded-full" aria-hidden="true"></span>

		<h2 class="relative text-2xl font-bold tracking-tight text-ink sm:text-3xl">
			{category.title}
		</h2>
	</div>

	<div class="grid gap-3 sm:grid-cols-2">
		{category.repos.map((repo, repoIndex) => (
			<RepoCard repo={repo} index={repoIndex} accent={accent} />
		))}
	</div>
</section>
