---
import { site } from "../data/site";
import ThemeToggle from "./ThemeToggle.astro";
---

<header class="site-header fixed top-0 z-50 w-full bg-canvas/70 backdrop-blur-md">
	<div class="site-header__inner mx-auto max-w-7xl px-4 py-5 sm:px-6">
		<span class="site-header__brand text-sm font-semibold uppercase tracking-[0.2em] text-ink">
			{site.name}
		</span>

		<div class="site-header__center">
			<ThemeToggle />
		</div>

		<nav class="site-header__nav flex items-center justify-end gap-3 sm:gap-6">
			<a
				href="#software"
				class="modern-only hidden text-xs font-medium uppercase tracking-[0.16em] text-muted transition hover:text-ink sm:inline"
			>
				Software
			</a>
			<a
				href={site.links.github}
				target="_blank"
				rel="noopener noreferrer"
				class="header-github inline-flex items-center gap-2 border border-line px-3 py-2 text-xs font-medium uppercase tracking-[0.14em] text-ink transition hover:border-accent/40 hover:text-accent sm:px-4"
				aria-label="GitHub profile"
			>
				<svg class="h-3.5 w-3.5 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
					<path
						d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.44 9.8 8.2 11.38.6.11-.82-.26.82-.58 0-.29-.01-1.04-.02-2.04-3.34.73-4.04-1.61-4.04-1.61-.54-1.38-1.35-1.75-1.35-1.75-1.1-.75.08-.74.08-.74 1.22.09 1.86 1.25 1.86 1.25 1.08 1.85 2.83 1.32 3.52 1.01.11-.78.42-1.32.76-1.62-2.67-.3-5.48-1.34-5.48-5.96 0-1.32.47-2.39 1.24-3.23-.12-.3-.54-1.52.12-3.17 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 3-.4c1.02.01 2.05.14 3 .4 2.29-1.55 3.3-1.23 3.3-1.23.66 1.65.24 2.87.12 3.17.77.84 1.24 1.91 1.24 3.23 0 4.63-2.81 5.66-5.49 5.95.43.37.81 1.1.81 2.22 0 1.6-.01 2.89-.01 3.28 0 .32.22.7.83.58A12.01 12.01 0 0 0 24 12c0-6.63-5.37-12-12-12Z"
					></path>
				</svg>
				<span class="hidden sm:inline">GitHub</span>
			</a>
		</nav>
	</div>
</header>
