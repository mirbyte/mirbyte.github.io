---
import { site } from "../data/site";

const year = new Date().getFullYear();
---

<footer class="site-footer border-t border-line/60">
	<div
		class="mx-auto flex max-w-7xl flex-col items-start justify-between gap-3 px-6 py-8 text-sm text-muted sm:flex-row sm:items-center"
	>
		<p>© {year} {site.name}</p>
		<a
			href={site.links.github}
			target="_blank"
			rel="noopener noreferrer"
			class="transition hover:text-accent"
		>
			@{site.username}
		</a>
	</div>
</footer>
