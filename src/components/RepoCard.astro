---
import type { Repo } from "../data/repos";

interface Props {
	repo: Repo;
}

const { repo } = Astro.props;

const meta = [repo.language, ...(repo.topics?.slice(0, 2) ?? [])].filter(Boolean);
---

<article
	class="group border border-line bg-surface-raised p-5 transition hover:border-accent/35 hover:bg-surface"
>
	<div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between sm:gap-6">
		<h3 class="text-lg font-semibold text-ink">
			<a
				href={repo.url}
				target="_blank"
				rel="noopener noreferrer"
				class="inline-flex items-center gap-2 transition group-hover:text-accent"
			>
				<span>{repo.name}</span>
				<svg
					class="h-3.5 w-3.5 text-accent opacity-70 transition group-hover:opacity-100"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					aria-hidden="true"
				>
					<path d="M7 17 17 7"></path>
					<path d="M7 7h10v10"></path>
				</svg>
			</a>
		</h3>

		{
			meta.length > 0 && (
				<ul class="flex flex-wrap gap-2 sm:justify-end">
					{meta.map((tag) => (
						<li class="rounded-sm border border-line bg-canvas px-2.5 py-1 font-mono text-xs text-secondary">
							{tag}
						</li>
					))}
				</ul>
			)
		}
	</div>

	<p class="mt-1 text-base leading-relaxed text-secondary">
		{repo.description}
	</p>
</article>
