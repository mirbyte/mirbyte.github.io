---
import type { Repo } from "../data/repos";

interface Props {
	repo: Repo;
	index: number;
	accent: string;
}

const { repo, index, accent } = Astro.props;

const meta = [repo.language, ...(repo.topics?.slice(0, 2) ?? [])].filter(Boolean);
---

<article
	class="repo-card reveal-card group relative overflow-hidden border border-line bg-surface-raised p-5 transition duration-300 hover:border-[color:var(--card-accent)]/45 hover:bg-surface"
	style={`--card-accent: ${accent}; --reveal-delay: ${index * 80}ms`}
>
	{
		repo.isNew && (
			<>
				<span class="repo-new-watermark pointer-events-none absolute select-none" aria-hidden="true">
					NEW
				</span>
				<span class="sr-only">Recently added</span>
			</>
		)
	}

	<div class="relative z-[1] grid grid-cols-[minmax(0,1fr)_auto] items-center gap-x-3 gap-y-3">
		<h3 class="min-w-0 text-lg font-semibold leading-tight text-ink">
			<a
				href={repo.url}
				target="_blank"
				rel="noopener noreferrer"
				class="repo-link transition duration-300 group-hover:text-[color:var(--card-accent)]"
				style={`--cursor-accent: ${accent}`}
				data-cursor-label="Open on GitHub"
			>
				{repo.name}
				<svg
					class="repo-card-arrow ml-1.5 inline-block h-3.5 w-3.5 shrink-0 align-[-0.125em] text-[color:var(--card-accent)] opacity-70 transition duration-300 group-hover:opacity-100"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					aria-hidden="true"
				>
					<path d="M7 17 17 7"></path>
					<path d="M7 7h10v10"></path>
				</svg>
			</a>
		</h3>

		<div class="flex items-center justify-end gap-2">
			{
				repo.downloadUrl && (
					<a
						href={repo.downloadUrl}
						target="_blank"
						rel="noopener noreferrer"
						class="repo-download inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-sm text-[#34d399] transition duration-300 hover:bg-[#34d399]/12 hover:text-[#6ee7b7]"
						aria-label={`Download ${repo.name} release`}
						data-cursor-label="Download latest"
					>
						<svg
							class="h-4 w-4"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"
							aria-hidden="true"
						>
							<path d="M12 3v12"></path>
							<path d="m7 10 5 5 5-5"></path>
							<path d="M5 21h14"></path>
						</svg>
					</a>
				)
			}
			{
				meta.length > 0 && (
					<ul class="flex flex-wrap justify-end gap-1">
						{meta.map((tag) => (
							<li class="shrink-0 rounded-sm border border-line bg-canvas px-2 py-1 font-mono text-xs leading-tight text-secondary">
								{tag}
							</li>
						))}
					</ul>
				)
			}
		</div>

		<p class="col-span-2 text-base leading-relaxed text-secondary transition duration-300 group-hover:text-secondary/90">
			{repo.description}
		</p>
	</div>
</article>
