---
import type { Repo } from "../data/repos";

interface Props {
	repo: Repo;
	index: number;
	accent: string;
}

const { repo, index, accent } = Astro.props;

const meta = [repo.language, ...(repo.topics?.slice(0, 2) ?? [])].filter(Boolean);
---

<article
	class="repo-card reveal-card group relative overflow-hidden border border-line bg-surface-raised p-5 transition duration-300 hover:border-[color:var(--card-accent)]/45 hover:bg-surface"
	style={`--card-accent: ${accent}; --reveal-delay: ${index * 80}ms`}
>
	<div class="grid grid-cols-[minmax(0,1fr)_auto] items-center gap-x-3 gap-y-3">
		<h3 class="min-w-0 text-lg font-semibold leading-tight text-ink">
			<a
				href={repo.url}
				target="_blank"
				rel="noopener noreferrer"
				class="transition duration-300 group-hover:text-[color:var(--card-accent)]"
			>
				{repo.name}
				<svg
					class="repo-card-arrow ml-1.5 inline-block h-3.5 w-3.5 shrink-0 align-[-0.125em] text-[color:var(--card-accent)] opacity-70 transition duration-300 group-hover:opacity-100"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					aria-hidden="true"
				>
					<path d="M7 17 17 7"></path>
					<path d="M7 7h10v10"></path>
				</svg>
			</a>
		</h3>

		<div class="flex items-center justify-end gap-3">
			{
				meta.length > 0 && (
					<ul class="flex flex-wrap justify-end gap-1">
						{meta.map((tag) => (
							<li class="shrink-0 rounded-sm border border-line bg-canvas px-2 py-1 font-mono text-xs leading-tight text-secondary">
								{tag}
							</li>
						))}
					</ul>
				)
			}
		</div>

		<p class="col-span-2 text-base leading-relaxed text-secondary transition duration-300 group-hover:text-secondary/90">
			{repo.description}
		</p>
	</div>
</article>
